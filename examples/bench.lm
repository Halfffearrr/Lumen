// 一个自计时的微型 benchmark，使用内置函数 clock() 获取当前时间。
// 这里计算朴素递归 fib(30)，它会产生大量函数调用和整数运算，
// 因此可以用来观察字节码虚拟机的函数调用路径表现。
// 运行方式：lumen examples/bench.lm

fn fib(n) {
    if n < 2 { return n }
    return fib(n - 1) + fib(n - 2)
}

let n = 30
let start = clock()
let result = fib(n)
let elapsed = clock() - start

print("fib({n}) = {result}")
print("elapsed seconds: {elapsed}")
